{
  "version": 8,
  "name": "Basic Line",
  "sources": {
    "martin_source": {
      "type": "vector",
      "tiles": [
        "http://127.0.0.1:${PORT}/table.public.Dataset.spatialGeom/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "lines",
      "type": "line",
      "source": "martin_source",
      "source-layer": "Dataset",
      "paint": {
        "line-color": "#b2452f",
        "line-opacity": 0.85,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.75,
          12,
          3
        ]
      }
    }
  ]
}
